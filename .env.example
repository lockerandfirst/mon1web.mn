# Next.js + Backend API — жишээ. Утгыг .env хуулж бөглөнө.

# Clerk
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Supabase (вэб + backend)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Schema dump: npm run db:dump-public-schema (Dockerгүй — pg_dump + доорх URI)
# Dashboard → Settings → Database → «Connection string» → URI-г Session эсвэл Direct-ээс БҮРЭН хууна.
# «db.xxx.supabase.co» зарим DNS-д олдохгүй; pooler (xxx.pooler.supabase.com) URI ашиглах нь илүү найдвартай.
# macOS: brew install libpq (pg_dump PATH-д орно)
# SUPABASE_DB_URL=postgresql://postgres.toerckwkbgdlntzywrkh:[PASSWORD]@aws-0-REGION.pooler.supabase.com:6543/postgres

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Backend API
API_PORT=4000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# Production: заавал (CORS)
# FRONTEND_ORIGIN=https://mon1web.mn
